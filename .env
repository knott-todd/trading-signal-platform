# Required — Alpaca live trading account credentials
# Register at https://alpaca.markets — live account required for real-time stream data
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Set by docker-compose for containerised runs. Override for local dev.
# DATABASE_URL=postgresql+asyncpg://perception:perception@localhost:5432/perception

# Optional — defaults shown
STREAM_RESOLUTIONS=1m,5m
STREAM_FALLBACK_POLL_SECONDS=60
MAX_WATCHLIST_SIZE=50
MAX_STREAM_TICKERS=25
TIMEZONE=US/Eastern

# Gateway
INGESTION_API_URL=http://backend:8000
GATEWAY_PORT=8080
SSE_KEEPALIVE_SECONDS=30
